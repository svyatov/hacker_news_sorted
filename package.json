{
  "name": "hacked_news_sorted",
  "version": "2.6.2",
  "description": "Instantly sort Hacker News by points, time, comments, velocity, or heat, mark new posts, and highlight comment authors.",
  "author": "Leonid Svyatov <leonid@svyatov.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "package": "wxt zip",
    "release": "bun run build && bun run package",
    "test": "vitest run",
    "test:integration": "vitest run app/utils/selectors.integration.test.ts app/utils/comments.integration.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint . && prettier --check .",
    "fixture:update": "bun app/__fixtures__/updateFixture.ts",
    "screenshots": "bun scripts/generate-screenshots.ts",
    "demo": "bun scripts/generate-demo.ts",
    "postinstall": "wxt prepare",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome lint --no-errors-on-unmatched",
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "baseline-browser-mapping": "^2.10.43",
    "caniuse-lite": "^1.0.30001799",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  },
  "manifest": {
    "host_permissions": [
      "https://news.ycombinator.com/*"
    ]
  },
  "overrides": {
    "caniuse-lite": "^1.0.30001799",
    "msgpackr": "^1.11.2",
    "lmdb": "^3.4.4",
    "svelte": "^4.2.19",
    "content-security-policy-parser": "^0.6.0"
  }
}
